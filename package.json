{
  "name": "piworker-os",
  "version": "2.0.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/preflight-check.mjs",
    "build": "next build",
    "build:sovereign": "./scripts/sovereign-build.sh",
    "build:cli": "go build -o bin/piworker-cli cmd/piworker/main.go",
    "start": "next start",
    "forge": "go run dev.go",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "profile:slo": "node scripts/profile-slo.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@tailwindcss/postcss": "4.0.0-alpha.1",
    "axios": "^1.7.7",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.11",
    "lucide-react": "^0.454.0",
    "next": "15.1.9",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "4.0.0-alpha.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@secretlint/secretlint-rule-preset-recommend": "^12.2.0",
    "@types/node": "^20",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8",
    "prettier": "^3.8.3",
    "secretlint": "^12.2.0"
  },
  "overrides": {
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0"
  },
  "lint-staged": {
    "*.{js,ts,tsx,md,json}": [
      "prettier --write"
    ]
  }
}
