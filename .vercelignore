# Vercel Ignore: Sovereign Assets
# Allow sidecar source for build and runtimes
!sidecar/
sidecar/**/bin/
sidecar/**/obj/
sidecar/**/*.exe
sidecar/**/*.log
!sidecar/physical-bridge/
!sidecar/sovereign-engine/
# Allow build scripts
!scripts/
bin/
# Allow api/ functions
!api/
# Allow Go module files for runtime detection
!go.mod
!go.sum
!proto/
.git/
node_modules/
.next/
out/
