{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/muscle/(.*)",
      "destination": "/api/index.go"
    },
    {
      "source": "/sovereign.SovereignService/(.*)",
      "destination": "/api/index.go"
    }
  ],
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://axiomid.app",
    "SOVEREIGN_ENGINE_URL": "https://axiomid.app"
  }
}
