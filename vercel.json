{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/sovereign/(.*)",
      "destination": "/api/index.go"
    }
  ],
  "functions": {
    "api/*.go": {
      "runtime": "vercel-go@3.0.0"
    }
  },
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://axiomid.app"
  }
}
